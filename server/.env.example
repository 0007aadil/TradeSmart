# Copy to .env and fill in.
PORT=4000
JWT_SECRET=change-me-to-a-long-random-string
# Get a free key at https://finnhub.io/dashboard . Leave blank to use simulated prices.
FINNHUB_API_KEY=
# Comma-separated symbols to stream. Leave unset to use the built-in 25-symbol universe.
# Examples: SYMBOLS=AAPL,MSFT,GOOGL,...
# SYMBOLS=
